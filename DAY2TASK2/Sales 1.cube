  <MdxScripts>
    <MdxScript dwd:design-time-name="7169d80d-2081-492e-9f2e-24d1fb1a3cd3">
      <ID>MdxScript</ID>
      <Name>MdxScript</Name>
      <CreatedTimestamp>0001-01-01T00:00:00Z</CreatedTimestamp>
      <LastSchemaUpdate>0001-01-01T00:00:00Z</LastSchemaUpdate>
      <Commands>
        <Command>
          <Text>/*
The CALCULATE command controls the aggregation of leaf cells in the cube.
If the CALCULATE command is deleted or modified, the data within the cube is affected.
You should edit this command only if you manually specify how the cube is aggregated.
*/
CALCULATE;  
CREATE MEMBER CURRENTCUBE.[Measures].SalesUnitePrice
 AS [Measures].[Qty Total Price]/[Measures].[Qty], 
FORMAT_STRING = "Currency", 
VISIBLE = 1  ; </Text>
        </Command>
      </Commands>
      <CalculationProperties>
        <CalculationProperty dwd:design-time-name="757b250c-29a2-4ab3-ae18-2819b3b6171d">
          <CalculationReference>[Measures].SalesUnitePrice</CalculationReference>
          <CalculationType>Member</CalculationType>
          <Translations>
            <Translation dwd:design-time-name="ac5a465e-d2c5-4038-ba18-569551f94f0d">
              <Language>3073</Language>
              <Caption>سعر البيع للوحدة</Caption>
            </Translation>
          </Translations>
        </CalculationProperty>
      </CalculationProperties>
    </MdxScript>
  </MdxScripts>
  <Kpis>
    <Kpi dwd:design-time-name="efea1701-ed55-4768-bec5-84a1d3df73c5">
      <ID>KPI</ID>
      <Name>QtyKPI</Name>
      <Value>[Measures].[Qty]</Value>
      <Goal>1000</Goal>
      <Status>case 
    when kpivalue('QtyKPI')&gt;1000 then 1
    when kpivalue('QtyKPI')&lt;1000 then -1
    else 0
end</Status>
      <TrendGraphic>Status Arrow - Ascending</TrendGraphic>
      <StatusGraphic>Smiley Face</StatusGraphic>
    </Kpi>
  </Kpis>
</Cube>